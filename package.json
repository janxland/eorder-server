{
  "name": "nest-jwt-typeorm",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build && ncc build ./dist/src/main.js -o ncc-dist",
    "build:prod": "nest build && ncc build ./dist/src/main.js -o ncc-dist --minify",
    "build:standalone": "nest build && ncc build ./dist/src/main.js -o deploy --minify --no-cache --no-source-map-register",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/src/main",
    "start:standalone": "node deploy/index.js",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "deploy:prepare": "npm run build:standalone && cp package.json deploy/ && cp .env deploy/ && cp -r migrations deploy/ 2>/dev/null || :",
    "deploy:clean": "rm -rf deploy/node_modules",
    "script:insert-permissions": "ts-node -r tsconfig-paths/register scripts/insert-api-permissions.ts"
  },
  "dependencies": {
    "@nestjs/common": "^10.0.0",
    "@nestjs/config": "^3.1.1",
    "@nestjs/core": "^10.0.0",
    "@nestjs/jwt": "^10.1.1",
    "@nestjs/mapped-types": "^2.0.2",
    "@nestjs/passport": "^10.0.2",
    "@nestjs/platform-express": "^10.0.0",
    "@nestjs/swagger": "^7.4.2",
    "@nestjs/typeorm": "^10.0.0",
    "@types/crypto-js": "^4.2.2",
    "@types/multer": "^1.4.12",
    "ali-oss": "^6.23.0",
    "amqplib": "^0.10.5",
    "axios": "^1.7.9",
    "bcryptjs": "^2.4.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.0",
    "cookie-parser": "^1.4.7",
    "cos-nodejs-sdk-v5": "^2.16.0-beta.3",
    "crypto-js": "^4.2.0",
    "express-session": "^1.17.3",
    "mysql2": "^3.6.3",
    "passport-jwt": "^4.0.1",
    "passport-local": "^1.0.0",
    "path-to-regexp": "^6.2.1",
    "qcloud-cos-sts": "^3.1.3",
    "qiniu": "^7.14.0",
    "redis": "^4.6.11",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.8.1",
    "svg-captcha": "^1.4.0",
    "swagger-ui-express": "^5.0.1",
    "typeorm": "^0.3.17",
    "utility": "^2.5.0",
    "uuid": "^11.0.5"
  },
